# xShield e-Clinic — Production ortam değişkenleri
# Bu dosyayı .env.prod olarak kopyalayın ve değerleri doldurun:
#   cp .env.prod.example .env.prod
#
# .env.prod dosyasını GIT'e commit ETMEYİN.

# ─── Veritabanı ───────────────────────────────────────────────────────────────
DB_PASSWORD=Guclu_Bir_Sifre_123!

# ─── JWT ─────────────────────────────────────────────────────────────────────
# En az 32 karakter, rastgele bir dize kullanın
# Üretmek için: openssl rand -base64 48
JWT_KEY=cok-guclu-ve-uzun-bir-jwt-secret-key-buraya-yazin
JWT_EXPIRE_MINUTES=480

# ─── SMTP (E-posta) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SSL=true
SMTP_USER=email@xshield.com.tr
SMTP_PASS=uygulama-sifresi
SMTP_FROM=noreply@xshield.com.tr
SMTP_FROM_NAME=xShield e-Clinic

# ─── Domain (nginx + frontend API URL) ───────────────────────────────────────
# Subdomain olarak yayınlanacak alan adı
PUBLIC_DOMAIN=eclinic.xshield.com.tr
